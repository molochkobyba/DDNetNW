<Window x:Class="DDNetNW.SelectRegionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select regions"
        Width="420" Height="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}">
    <Border Margin="18" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock x:Name="TitleText" Text="Tracked server regions" FontSize="22" FontWeight="Bold"/>
                <TextBlock x:Name="SubtitleText" Text="Choose where map alerts should look for active servers." Foreground="{DynamicResource TextMuted}" FontSize="13" TextWrapping="Wrap" Margin="0,6,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,18,0,0">
                <CheckBox x:Name="AnyCheck" Style="{StaticResource ModernCheckBox}" Content="Any region" Margin="0,0,0,12" Checked="AnyCheck_Changed" Unchecked="AnyCheck_Changed"/>
                <Separator Background="{DynamicResource BlueBorder}" Margin="0,0,0,12"/>
                <UniformGrid Columns="2">
                    <CheckBox x:Name="GerCheck" Style="{StaticResource ModernCheckBox}" Content="GER" Margin="0,0,8,12" Checked="RegionCheck_Changed" Unchecked="RegionCheck_Changed"/>
                    <CheckBox x:Name="RusCheck" Style="{StaticResource ModernCheckBox}" Content="RUS" Margin="8,0,0,12" Checked="RegionCheck_Changed" Unchecked="RegionCheck_Changed"/>
                    <CheckBox x:Name="PolCheck" Style="{StaticResource ModernCheckBox}" Content="POL" Margin="0,0,8,12" Checked="RegionCheck_Changed" Unchecked="RegionCheck_Changed"/>
                    <CheckBox x:Name="FraCheck" Style="{StaticResource ModernCheckBox}" Content="FRA" Margin="8,0,0,12" Checked="RegionCheck_Changed" Unchecked="RegionCheck_Changed"/>
                    <CheckBox x:Name="UsaCheck" Style="{StaticResource ModernCheckBox}" Content="USA" Margin="0,0,8,12" Checked="RegionCheck_Changed" Unchecked="RegionCheck_Changed"/>
                    <CheckBox x:Name="BraCheck" Style="{StaticResource ModernCheckBox}" Content="BRA" Margin="8,0,0,12" Checked="RegionCheck_Changed" Unchecked="RegionCheck_Changed"/>
                </UniformGrid>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="CancelButton" Style="{StaticResource SecondaryButton}" Content="Cancel" MinWidth="92" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button x:Name="SaveButton" Style="{StaticResource PrimaryButton}" Content="Save" MinWidth="92" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
