<Application x:Class="DDNetNW.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#07111F"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#0B1628"/>
        <SolidColorBrush x:Key="CardBackground" Color="#101A2B"/>
        <SolidColorBrush x:Key="CardHoverBackground" Color="#17243A"/>
        <SolidColorBrush x:Key="TextMain" Color="#F3F7FF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8FA3BF"/>
        <SolidColorBrush x:Key="BlueAccent" Color="#3A86FF"/>
        <SolidColorBrush x:Key="BlueBorder" Color="#244A78"/>
        <SolidColorBrush x:Key="GreenAccent" Color="#3DFF9F"/>
        <SolidColorBrush x:Key="RedAccent" Color="#FF4F6D"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F3F7FF"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,12"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#143B67"/>
            <Setter Property="BorderBrush" Value="#326AA5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="12" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D538E"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4DA3FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0F2F55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoftButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#0D1D33"/>
            <Setter Property="BorderBrush" Value="#244A78"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="MinWidth" Value="112"/>
        </Style>

        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#B8C7DB"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="14,5"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" CornerRadius="14" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" Padding="18,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#111F35"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1D3D66"/>
                                <Setter Property="Foreground" Value="#F3F7FF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#15365C"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3A86FF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F3F7FF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box" Width="32" Height="32" CornerRadius="10" Background="#07111F" BorderBrush="#244A78" BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock x:Name="CheckMark" Text="✓" FontSize="22" FontWeight="Bold" Foreground="#3DFF9F" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0" Margin="0,-2,0,0"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#3A86FF"/>
                                <Setter TargetName="Box" Property="Background" Value="#0D1D33"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#3DFF9F"/>
                                <Setter TargetName="Box" Property="Background" Value="#0C2A25"/>
                                <Setter TargetName="CheckMark" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Margin="0,6">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="8" CornerRadius="4" Background="#3A86FF"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="8" CornerRadius="4" Background="#10223B" BorderBrush="#244A78" BorderThickness="1"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="24" Height="24">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="12" Background="#F3F7FF" BorderBrush="#3A86FF" BorderThickness="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
