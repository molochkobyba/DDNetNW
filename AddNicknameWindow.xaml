<Window x:Class="DDNetNW.AddNicknameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DDNetNW - Add nickname"
        Width="560" Height="370" MinWidth="480" MinHeight="340"
        Background="{DynamicResource AppBackground}"
        Icon="Assets/icon_transparent.png"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize">
    <Border Background="{DynamicResource AppBackground}">
        <Border Margin="1" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource TitleBarBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="0,0,0,1" CornerRadius="18,18,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="10,0,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Assets/icon_transparent.png" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock x:Name="DialogTitleBarText" Text="Add nickname" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="✕" Width="34" Height="26" Background="Transparent" BorderBrush="Transparent" Foreground="{DynamicResource TextMain}" Cursor="Hand" Click="Cancel_Click" Style="{StaticResource TitleBarButton}"/>
                    </Grid>
                </Border>
                <Grid Grid.Row="1" Margin="28,26,28,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="DialogHeaderText" Text="Add nickname" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:Name="DialogDescriptionText" Text="Enter the exact DDNet nickname to watch." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,22,0,0">
                        <TextBlock x:Name="NicknameLabelText" Text="Nickname" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="2,0,0,8"/>
                        <TextBox x:Name="NicknameBox" Style="{StaticResource ModernTextBox}" Height="42"/>
                        <TextBlock x:Name="ErrorText" Foreground="{DynamicResource RedAccent}" FontSize="13" Margin="2,8,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                        <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="Cancel_Click"/>
                        <Button x:Name="SaveButton" Content="Add" Style="{StaticResource PrimaryButton}" Click="Add_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
