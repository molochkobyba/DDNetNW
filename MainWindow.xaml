<Window x:Class="DDNetNW.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:DDNetNW.Models"
        Title="DDNetNW" Width="1400" Height="860" MinWidth="1120" MinHeight="720"
        Background="{DynamicResource AppBackground}"
        Icon="Assets/icon_transparent.png"
        WindowStyle="None" ResizeMode="CanResizeWithGrip">
    <Border Background="{DynamicResource AppBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource TitleBarBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="10,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Assets/icon_transparent.png" Width="22" Height="22" Margin="2,0,8,0"/>
                        <TextBlock x:Name="WindowTitleText" Text="DDNetNW v1.35" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource TitleBarButton}" Content="—" Click="MinimizeButton_Click"/>
                        <Button Style="{StaticResource TitleBarButton}" Content="▢" Margin="6,0,0,0" Click="MaximizeButton_Click"/>
                        <Button Style="{StaticResource CloseTitleBarButton}" Content="✕" Margin="6,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="0,0,1,0">
                <Grid Margin="14,16,14,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Image Source="Assets/icon_transparent.png" Width="54" Height="54" HorizontalAlignment="Left"/>
                        <TextBlock Text="DDNetNW" FontSize="20" FontWeight="Bold" Margin="0,12,0,0"/>
                        <TextBlock x:Name="SidebarVersionText" Text="v1.35" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,20,0,0">
                        <RadioButton x:Name="AboutNav" Style="{StaticResource NavButton}" GroupName="NavGroup" Tag="About" Checked="Navigation_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ⓘ" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" FontSize="20" Margin="0,0,12,0"/>
                                <TextBlock x:Name="AboutNavText" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Text="About" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,44,0,0">
                        <RadioButton x:Name="HomeNav" Style="{StaticResource NavButton}" GroupName="NavGroup" Tag="Home" Checked="Navigation_Checked" IsChecked="True">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⌂" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" FontSize="20" Margin="0,0,12,0"/>
                                <TextBlock x:Name="HomeNavText" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Text="Main menu" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NotificationsNav" Style="{StaticResource NavButton}" GroupName="NavGroup" Tag="Notifications" Checked="Navigation_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔔" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock x:Name="NotificationsNavText" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Text="Notifications" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="OptionsNav" Style="{StaticResource NavButton}" GroupName="NavGroup" Tag="Options" Checked="Navigation_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" FontSize="18" Margin="0,0,12,0"/>
                                <TextBlock x:Name="OptionsNavText" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Text="Options" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <Border Grid.Row="4" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="18" Padding="14">
                        <StackPanel>
                            <TextBlock x:Name="SidebarEventsTitle" Text="Recent events" FontSize="16" FontWeight="Bold"/>
                            <ItemsControl ItemsSource="{Binding Events}" Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Separator Margin="0,10,0,8" Background="{DynamicResource BlueBorder}"/>
                            <TextBlock x:Name="SidebarStateText" Text="Ready" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource GreenAccent}"/>
                            <TextBlock x:Name="SidebarScanText" Text="Last scan: —" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Grid.Column="1" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid x:Name="HomePage">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="HomeHeaderText" Text="Main menu" FontSize="28" FontWeight="Bold"/>
                            <TextBlock x:Name="HomeSubheaderText" Text="Watch DDNet players and maps from the public server list." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="{DynamicResource NavBackground}" BorderBrush="{DynamicResource NavBorder}" BorderThickness="1" CornerRadius="17" Padding="4" Margin="0,0,12,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="PlayersModeButton" Style="{StaticResource SegmentButton}" GroupName="HomeMode" Content="Players" Tag="Players" IsChecked="True" Checked="HomeMode_Checked"/>
                                <RadioButton x:Name="MapsModeButton" Style="{StaticResource SegmentButton}" GroupName="HomeMode" Content="Maps" Tag="Maps" Checked="HomeMode_Checked"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="{DynamicResource StateOnlineBadgeBackground}" BorderBrush="{DynamicResource StateOnlineBorder}" BorderThickness="1" CornerRadius="18" Padding="16,8" Margin="0,0,12,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TopStatusText" Text="● Monitoring ON" Foreground="{DynamicResource StateOnlineBadgeForeground}" FontWeight="SemiBold"/>
                        </Border>
                        <Button Grid.Column="3" x:Name="AddNicknameButton" Style="{StaticResource PrimaryButton}" Content="+ Add nickname" MinWidth="160" Visibility="Collapsed" Click="AddNickname_Click"/>
                        <Button Grid.Column="3" x:Name="AddMapButton" Style="{StaticResource PrimaryButton}" Content="+ Add map" MinWidth="160" Visibility="Collapsed" Click="AddMap_Click"/>
                    </Grid>

                    <Border Grid.Row="2" Margin="0,20,0,0" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="14">
                        <Grid>
                            <Grid x:Name="PlayersPanel">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CardsTitleText" Text="Watched nicknames" Style="{StaticResource SectionTitle}"/>
                                    <Button Grid.Column="1" x:Name="ScanNowButton" Style="{StaticResource SecondaryButton}" Content="Scan now" Click="ScanNow_Click"/>
                                </Grid>
                                <Border Grid.Row="1" Margin="0,14,0,0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="18" Padding="14">
                                    <StackPanel>
                                        <TextBlock x:Name="SearchTitleText" Text="Quick nickname search" FontSize="15" FontWeight="SemiBold"/>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="SearchNicknameBox" Style="{StaticResource ModernTextBox}" MinHeight="42" VerticalContentAlignment="Center" KeyDown="SearchNicknameBox_KeyDown" TextChanged="SearchNicknameBox_TextChanged"/>
                                            <Button Grid.Column="1" x:Name="SearchNicknameButton" Style="{StaticResource SecondaryButton}" Content="Search" MinWidth="118" Margin="10,0,0,0" Click="SearchNickname_Click"/>
                                        </Grid>

                                        <Border x:Name="SearchResultStrip" Visibility="Collapsed" Margin="0,10,0,0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="14" Padding="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock x:Name="SearchResultStatusDot" Text="●" FontSize="15" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="SearchResultNicknameText" Text="Nickname" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="SearchResultClanText" Text="Clan: —" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="18,0,0,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="SearchResultMapText" Text="Map: —" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="18,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" x:Name="SearchResultAddButton" Style="{StaticResource SecondaryButton}" Content="+ Watch" MinHeight="34" Padding="14,6" Margin="12,0,0,0" Click="AddSearchResult_Click"/>
                                                <Button Grid.Column="2" x:Name="SearchResultClearButton" Style="{StaticResource IconButton}" Content="×" Width="34" Height="34" Margin="8,0,0,0" Click="ClearSearchResult_Click"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="2" Margin="0,14,0,0">
                                    <Border x:Name="EmptyState" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="18" Padding="20" Visibility="Collapsed">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="EmptyStateTitle" Text="No nicknames yet" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="EmptyStateText" Text="Add a nickname to start monitoring." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding Players}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:PlayerCard}">
                                                    <Border Background="{DynamicResource CardBackground}" BorderBrush="{Binding BorderBrush}" BorderThickness="1" CornerRadius="20" Margin="6,0,6,12" Padding="18">
                                                        <StackPanel>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="●" Foreground="{Binding BorderBrush}" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding Nickname}" FontSize="19" FontWeight="Bold" VerticalAlignment="Center"/>
                                                                    <Border Background="{Binding BadgeBackground}" BorderBrush="{Binding BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10,4" Margin="12,0,0,0" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding BadgeForeground}" FontSize="12" FontWeight="SemiBold"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                    <Button Content="⋯" Style="{StaticResource IconButton}" Tag="{Binding}" ToolTip="Details" Click="ToggleDetails_Click"/>
                                                                    <Button Content="✎" Style="{StaticResource IconButton}" Tag="{Binding}" ToolTip="Edit" Margin="8,0,0,0" Click="EditNickname_Click"/>
                                                                    <Button Content="🗑" Style="{StaticResource IconButton}" Tag="{Binding}" ToolTip="Delete" Margin="8,0,0,0" Click="RemoveNickname_Click"/>
                                                                </StackPanel>
                                                            </Grid>
                                                            <TextBlock Text="{Binding SummaryLine}" FontSize="15" Margin="0,14,0,0" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding SecondaryLine}" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                                            <StackPanel Margin="0,10,0,0" Visibility="{Binding ExpandedVisibility}">
                                                                <TextBlock Text="{Binding DetailsLine}" Foreground="{DynamicResource TextMuted}" FontSize="13" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding AddressLine}" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="{Binding AddressVisibility}"/>
                                                                <TextBlock Text="{Binding ExtraDetailsLine}" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="{Binding ExtraVisibility}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>

                            <Grid x:Name="MapsOverviewPanel" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="MapsTitleText" Text="Watched maps" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock x:Name="MapsSubtitleText" Text="Open a map folder to see active servers." Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="ScanMapsButton" Style="{StaticResource SecondaryButton}" Content="Scan now" Click="ScanNow_Click"/>
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,14,0,0">
                                    <Border x:Name="EmptyMapsState" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="18" Padding="20" Visibility="Collapsed">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="EmptyMapsTitle" Text="No maps yet" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="EmptyMapsText" Text="Add a map to watch active servers." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding WatchedMaps}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:WatchedMapCard}">
                                                    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="20" Margin="6,0,6,12" Padding="18" Tag="{Binding}" Cursor="Hand" MouseLeftButtonUp="OpenMap_MouseLeftButtonUp">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold"/>
                                                                <TextBlock Text="{Binding ServersFoundLine}" FontSize="15" Margin="0,10,0,0"/>
                                                                <TextBlock Text="{Binding PlayersTotalLine}" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,5,0,0"/>
                                                                <TextBlock Text="{Binding BestServerLine}" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,5,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                                                <Button Content="✎" Style="{StaticResource IconButton}" Tag="{Binding}" ToolTip="Edit" Click="EditMap_Click"/>
                                                                <Button Content="🗑" Style="{StaticResource IconButton}" Tag="{Binding}" ToolTip="Delete" Margin="8,0,0,0" Click="RemoveMap_Click"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>

                            <Grid x:Name="MapDetailsPanel" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="BackToMapsButton" Style="{StaticResource SecondaryButton}" Content="← Back" Click="BackToMaps_Click" Margin="0,0,14,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="SelectedMapTitleText" Text="Map" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock x:Name="SelectedMapSummaryText" Text="0 servers • 0 players" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,14,0,0">
                                    <Border x:Name="NoMapServersState" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="18" Padding="20" Visibility="Collapsed">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="NoMapServersTitle" Text="No active servers" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="NoMapServersText" Text="This map is not active on the selected server filter." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding SelectedMapServers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:MapServerInfo}">
                                                    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="20" Margin="6,0,6,12" Padding="18">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding ServerName}" FontSize="20" FontWeight="Bold"/>
                                                                <TextBlock Text="{Binding PlayersLine}" FontSize="15" Margin="0,10,0,0"/>
                                                                <TextBlock Text="{Binding DetailsLine}" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                                                <Button Content="Copy address" Style="{StaticResource SecondaryButton}" Tag="{Binding}" Click="CopyServerAddress_Click"/>
                                                                <Button Content="Copy connect" Style="{StaticResource SecondaryButton}" Tag="{Binding}" Margin="8,0,0,0" Click="CopyConnectCommand_Click"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="NotificationsPage" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="NotificationsHeaderText" Text="Notifications" FontSize="28" FontWeight="Bold"/>
                        <TextBlock x:Name="NotificationsSubheaderText" Text="Choose which local Windows notifications should be shown." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,4,0,0"/>
                        <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,20,0,0">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="WindowsNotificationsTitle" Text="Windows notifications" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="WindowsNotificationsCheck" Grid.Column="1" Style="{StaticResource ModernCheckBox}" Content="On" Margin="0,0,12,0" Checked="NotificationOptionChanged" Unchecked="NotificationOptionChanged"/>
                                    <Button Grid.Column="2" x:Name="NotificationSettingsButton" Style="{StaticResource IconButton}" Content="⚙" Click="ToggleNotificationOptions_Click"/>
                                </Grid>
                                <StackPanel x:Name="NotificationOptionsPanel" Margin="0,18,0,0" Visibility="Collapsed">
                                    <CheckBox x:Name="NotifyJoinCheck" Style="{StaticResource ModernCheckBox}" Content="Notify when a player joins" Margin="0,0,0,10" Checked="NotificationOptionChanged" Unchecked="NotificationOptionChanged"/>
                                    <CheckBox x:Name="NotifyLeaveCheck" Style="{StaticResource ModernCheckBox}" Content="Notify when a player leaves" Margin="0,0,0,10" Checked="NotificationOptionChanged" Unchecked="NotificationOptionChanged"/>
                                    <CheckBox x:Name="NotifyServerCheck" Style="{StaticResource ModernCheckBox}" Content="Notify when a player changes server" Margin="0,0,0,10" Checked="NotificationOptionChanged" Unchecked="NotificationOptionChanged"/>
                                    <CheckBox x:Name="NotifyMapCheck" Style="{StaticResource ModernCheckBox}" Content="Notify when a player changes map" Margin="0,0,0,10" Checked="NotificationOptionChanged" Unchecked="NotificationOptionChanged"/>
                                    <CheckBox x:Name="MapAlertsCheck" Style="{StaticResource ModernCheckBox}" Content="Notify when watched maps reach the selected online" Margin="0,0,0,10" Checked="NotificationOptionChanged" Unchecked="NotificationOptionChanged"/>
                                    <CheckBox x:Name="PlaySoundCheck" Style="{StaticResource ModernCheckBox}" Content="Play a sound with notifications" Checked="NotificationOptionChanged" Unchecked="NotificationOptionChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,16,0,0" Opacity="0.82">
                            <StackPanel>
                                <TextBlock x:Name="DiscordTitleText" Text="Discord" FontSize="18" FontWeight="Bold"/>
                                <TextBlock x:Name="DiscordInfoText" Text="In development" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,16,0,0" Opacity="0.82">
                            <StackPanel>
                                <TextBlock x:Name="TelegramTitleText" Text="Telegram" FontSize="18" FontWeight="Bold"/>
                                <TextBlock x:Name="TelegramInfoText" Text="In development" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid x:Name="OptionsPage" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock x:Name="OptionsHeaderText" Text="Options" FontSize="28" FontWeight="Bold"/>
                            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,20,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="AppearanceTitleText" Style="{StaticResource SectionTitle}" Text="Appearance"/>
                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="LanguageLabelText" Text="Language" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Background="{DynamicResource NavBackground}" BorderBrush="{DynamicResource NavBorder}" BorderThickness="1" CornerRadius="17" Padding="4">
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="LanguageEnglishButton" Style="{StaticResource SegmentButton}" GroupName="LanguageGroup" Content="ENG" Tag="en" Checked="LanguageSegment_Checked"/>
                                                <RadioButton x:Name="LanguageRussianButton" Style="{StaticResource SegmentButton}" GroupName="LanguageGroup" Content="RUS" Tag="ru" Checked="LanguageSegment_Checked"/>
                                                <RadioButton x:Name="LanguageSpanishButton" Style="{StaticResource SegmentButton}" GroupName="LanguageGroup" Content="ESP" Tag="es" Checked="LanguageSegment_Checked"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="ThemeLabelText" Text="Theme" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Background="{DynamicResource NavBackground}" BorderBrush="{DynamicResource NavBorder}" BorderThickness="1" CornerRadius="17" Padding="4">
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="ThemeLightButton" Style="{StaticResource SegmentButton}" GroupName="ThemeGroup" Content="Light" Tag="light" Checked="ThemeSegment_Checked"/>
                                                <RadioButton x:Name="ThemeDarkButton" Style="{StaticResource SegmentButton}" GroupName="ThemeGroup" Content="Dark" Tag="dark" Checked="ThemeSegment_Checked"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="MonitoringTitleText" Style="{StaticResource SectionTitle}" Text="Monitoring"/>
                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="IntervalLabelText" Text="Scan interval" VerticalAlignment="Center"/>
                                        <Slider x:Name="CooldownSlider" Grid.Column="1" Style="{StaticResource ModernSlider}" Minimum="5" Maximum="180" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="CooldownSlider_ValueChanged"/>
                                        <TextBlock x:Name="CooldownValueText" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Text="30 s"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="MapsOptionsTitleText" Style="{StaticResource SectionTitle}" Text="Maps"/>
                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="MapAlertPlayersLabelText" Text="Alert online" VerticalAlignment="Center"/>
                                        <Slider x:Name="MapAlertPlayersSlider" Grid.Column="1" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="64" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="MapAlertPlayersSlider_ValueChanged"/>
                                        <TextBlock x:Name="MapAlertPlayersValueText" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Text="8"/>
                                    </Grid>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="MapServerFilterLabelText" Text="Server filter" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock x:Name="MapServerFilterValueText" Text="Any" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Button x:Name="ChangeMapServerFilterButton" Style="{StaticResource SecondaryButton}" Content="Change" MinWidth="96" Click="ChangeMapServerFilter_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="CardsOptionsTitleText" Style="{StaticResource SectionTitle}" Text="Card display"/>
                                    <CheckBox x:Name="ShowAddressCheck" Style="{StaticResource ModernCheckBox}" Content="Show server address in details" Margin="0,14,0,0" Checked="DisplayOptionChanged" Unchecked="DisplayOptionChanged"/>
                                    <CheckBox x:Name="ShowExtraDetailsCheck" Style="{StaticResource ModernCheckBox}" Content="Show extra player details" Margin="0,10,0,0" Checked="DisplayOptionChanged" Unchecked="DisplayOptionChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="AboutPage" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Image Source="Assets/icon_transparent.png" Width="96" Height="96" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="AboutHeaderText" Text="About" FontSize="28" FontWeight="Bold" Margin="0,18,0,0"/>
                            <TextBlock x:Name="AboutSummaryText" Text="DDNetNW checks selected nicknames and maps against the public DDNet server list." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,6,0,0" TextWrapping="Wrap"/>

                            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,20,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="AboutVersionText" Text="Version: v1.35" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="AboutCreatorText" Text="Originally created by molochko." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="AboutHowItWorksTitleText" Text="How it works" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock x:Name="AboutHowItWorksText" Text="The app reads DDNet servers.json, scans players and maps, and updates local cards." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="AboutFeaturesTitleText" Text="Main features" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock x:Name="AboutFeaturesText" Text="Player tracking, map folders, map online alerts, server filtering, local notifications, custom themes and bilingual UI." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="AboutDataTitleText" Text="Data source" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock x:Name="AboutDataText" Text="DDNetNW uses the public DDNet master server list. It does not log into DDNet and does not need a private server." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="AboutStorageTitleText" Text="Storage and privacy" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock x:Name="AboutStorageText" Text="Settings are stored locally in the user AppData folder. The app does not send watched nicknames or maps to any third-party service." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="AboutLimitationsTitleText" Text="Limitations" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock x:Name="AboutLimitationsText" Text="DDNet nicknames are not accounts. The app tracks public nickname text and public map/server activity, so visually similar names can still be different players." Foreground="{DynamicResource TextMuted}" FontSize="14" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Border Grid.Row="1" Margin="0,16,0,0" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BlueBorder}" BorderThickness="1" CornerRadius="18" Padding="16,10">
                    <DockPanel>
                        <TextBlock x:Name="FooterIntervalText" Text="Check every: 30 seconds" Foreground="{DynamicResource TextMuted}" FontSize="12" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="FooterPlayersText" Text="0 nicknames" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="16,0,0,0" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="FooterMapsText" Text="0 maps" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="16,0,0,0" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="FooterMasterText" Text="master status: waiting" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="16,0,0,0" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="FooterLastScanText" Text="Last scan: —" Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Right"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
